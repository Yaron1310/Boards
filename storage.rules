rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Organization logos — publicly readable, backend-only writes via Admin SDK
    match /organizationLogos/{orgId}/logo.webp {
      allow read: if true;
      allow write: if false;
    }

    // User profile images — publicly readable, backend-only writes via Admin SDK
    match /userProfileImages/{userId}/profile.webp {
      allow read: if true;
      allow write: if false;
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
