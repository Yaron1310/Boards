# Firebase client SDK config (get these from Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Named Firestore database ID. If omitted, falls back to VITE_FIREBASE_PROJECT_ID.
# Must match the database ID used by the backend (GCLOUD_PROJECT in Cloud Functions).
VITE_FIREBASE_DATABASE_ID=

# Optional — only needed if RECAPTCHA is enabled
VITE_RECAPTCHA_SITE_KEY=
